includes:
	- ./vendor/phpstan/phpstan/conf/bleedingEdge.neon
	- ./vendor/phpstan/phpstan-strict-rules/rules.neon
	- ./vendor/phpstan/phpstan-phpunit/extension.neon
parameters:
	level: max
	paths:
		- ./src
		- ./tests
		- ./bootstrap.php
	excludePaths:
		- ./tests/fixtures/*
	ignoreErrors:
		- '#Dynamic call to static method PHPUnit\\Framework\\.*#'
